<meta charset="utf-8">
<meta name="viewport" content="width=device-width, initial-scale=1">
<title>{{title or metadata.title}}</title>
<meta content="{{title or metadata.title}}" property="og:title">
<meta content="{{title or metadata.title}}" name="twitter:title">
<meta content="{{title or metadata.title}}" name="title">
<meta content="{{title or metadata.title}}" property="og:site_name">
<meta content="{{description or metadata.description}}" name="description">
<meta content="{{description or metadata.description}}" property="facebook:description">
<meta content="{{description or metadata.description}}" property="og:description">
<meta content="{{description or metadata.description}}" name="twitter:description">
<meta property="twitter:card" content="summary_large_image">
<meta content="{{image or metadata.metasocial.image}}" name="twitter:image">
<meta content="{{image or metadata.metasocial.image}}" name="facebook:image">
<meta content="{{image or metadata.metasocial.image}}" name="og:image">
<link href="{{metadata.favicon}}" rel="icon" type="image/x-icon">
<link rel="apple-touch-icon" href="{{metadata.favicon}}">
<meta content="{{metadata.metasocial.facebook}}" property="facebook:author">
<meta content="{{metadata.metasocial.twitteruser}}" property="twitter:author">
<meta content="{{metadata.metasocial.twitter}}" name="twitter:site">
<meta property="og:type" content="website">
<link rel="canonical" href="{% if canonical_url %}{{ canonical_url }}{% else %}{{ metadata.url }}{{ page.url }}{% endif %}"/>
<link rel="alternate" href="feed/feed.xml" type="application/atom+xml" title="{{ metadata.title }}">
<meta name="language" content="{{metadata.language}}">
<meta name="locale" content="{{metadata.locale}}">
<meta property="og:locale" content="{{metadata.locale}}">
<meta name="generator" content="{{ eleventy.generator }}"> 
<script type="application/ld+json">{"@context":"https://schema.org","@type":"WebSite","description":"{{metadata.description}}","headline":"{{metadata.title}} - {{metadata.description}}","name":"{{metadata.title}}","url":"{{metadata.url}}{{page.url}}"}</script>
<link href="https://fonts.googleapis.com/css2?display=swap&family=Roboto:ital,wght@0,400;0,700;0,900;1,400;1,700;1,900&family=Bebas+Neue:ital,wght@0,400;1,400" rel="stylesheet" type="text/css" />
<link rel="stylesheet" href="/assets/main.css" />
<noscript><link rel="stylesheet" href="/assets/noscript.css" /></noscript>
{%- js %}{% include "node_modules/@zachleat/heading-anchors/heading-anchors.js" %}{% endjs %}

{% set isCitable = layout == 'post' or layout == 'press' or "posts" in (tags or []) or "press" in (tags or []) %}
{% if isCitable %}
{% set pageCanonical = canonical_url or metadata.url + page.url %}
{% set itemType = "NewsArticle" if (layout == 'press' or "press" in (tags or [])) else "BlogPosting" %}
{% set zoteroType = "newspaperArticle" if itemType == "NewsArticle" else "blogPost" %}
<link rel="cite-as" href="{{ pageCanonical }}">
<link rel="type" href="https://schema.org/{{ itemType }}">
<link rel="author" href="{{ metadata.url }}">
<link rel="describedby" type="application/ld+json" profile="https://schema.org/" href="{{ page.url }}metadata.json">
<meta property="zotero:itemType" content="{{ zoteroType }}" />
<meta property="dc:title" content="{{ (title or metadata.title) | escape }}" />
<meta property="dc:creator" content="{{ metadata.title | escape }}" />
{% if date %}<meta property="dc:date" content="{{ date | htmlDateString }}" />{% endif %}
<meta property="dc:language" content="{{ metadata.language }}" />
<meta property="dc:identifier" content="{{ pageCanonical }}" />
<meta name="citation_title" content="{{ (title or metadata.title) | escape }}" />
<meta name="citation_author" content="{{ metadata.title | escape }}" />
{% if date %}<meta name="citation_publication_date" content="{{ date | htmlDateString }}" />{% endif %}
<meta name="citation_fulltext_html_url" content="{{ pageCanonical }}" />
<meta name="citation_public_url" content="{{ pageCanonical }}" />
<meta name="citation_language" content="{{ metadata.language }}" />
<meta name="prism.genre" content="{% if itemType == 'NewsArticle' %}article{% else %}blogentry{% endif %}" />
<meta name="prism.publicationName" content="{{ metadata.title | escape }}" />
{% endif %}
